APP_ENV=development
SECRET_KEY=replace-with-a-long-random-value
DATABASE_URL=sqlite:///dev.db
LOG_LEVEL=INFO
BETA_LAUNCH_ENABLED=false
CACHE_ENABLED=true
CACHE_DEFAULT_TTL_SECONDS=60
REDIS_URL=
QUEUE_WORKER_CONCURRENCY=1
REALTIME_WORKER_CONCURRENCY=1
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=120
RATE_LIMIT_WINDOW_SECONDS=60
EXPORT_MAX_ROWS=1000
OBSERVABILITY_LOG_REQUESTS=true
DEMO_LOGIN_HINTS_ENABLED=true
DEMO_SEED_ENABLED=true
DEMO_PASSWORD=password123
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=30
TEACHER_MIN_TRANSITION_MINUTES=30
TEACHER_DAILY_SESSION_WARNING=6
