APP_ENV=staging
SECRET_KEY=replace-with-a-staging-secret-with-at-least-32-bytes
DATABASE_URL=postgresql+psycopg://bimbelsaas:bimbelsaas@localhost:5433/bimbelsaas_staging
LOG_LEVEL=INFO
BETA_LAUNCH_ENABLED=true
CACHE_ENABLED=true
CACHE_DEFAULT_TTL_SECONDS=60
REDIS_URL=redis://localhost:6379/0
QUEUE_WORKER_CONCURRENCY=2
REALTIME_WORKER_CONCURRENCY=2
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=300
RATE_LIMIT_WINDOW_SECONDS=60
EXPORT_MAX_ROWS=1000
OBSERVABILITY_LOG_REQUESTS=true
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=30
TEACHER_MIN_TRANSITION_MINUTES=30
TEACHER_DAILY_SESSION_WARNING=6
